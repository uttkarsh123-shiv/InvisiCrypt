<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/avif" href="/images/logo.avif">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="logo">
                <div class="logo-icon">
                    <img src="/images/logo.avif" alt="InvisiCrypt Logo" class="logo-image">
                </div>
                <h2>InvisiCrypt</h2>
            </div>
            
            <nav class="nav-menu">
                <button class="nav-item active" data-view="hide">
                    <span class="icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                    </span>
                    <span>Hide Message</span>
                </button>
                <button class="nav-item" data-view="extract">
                    <span class="icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="m21 21-4.35-4.35"/>
                        </svg>
                    </span>
                    <span>Extract Message</span>
                </button>
                <button class="nav-item" data-view="about">
                    <span class="icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="16" x2="12" y2="12"/>
                            <line x1="12" y1="8" x2="12.01" y2="8"/>
                        </svg>
                    </span>
                    <span>About</span>
                </button>
            </nav>

            <div class="sidebar-footer">
                <p class="version">v1.0.0</p>
            </div>
        </aside>

        <main class="main-content">
            <header class="header">
                <h1 class="page-title">Built to hide. Designed to protect.</h1>
                <p class="page-subtitle">Steganography meets encryption - hide your secrets in plain sight</p>
            </header>

            <!-- Hide Message View -->
            <div id="hide-view" class="view active">
                <form id="hide-form" class="form-card">
                    <div class="form-group">
                        <label for="cover-text">Cover Text</label>
                        <textarea id="cover-text" name="coverText" rows="4" placeholder="Enter innocent-looking text here..."></textarea>
                        <div class="file-upload">
                            <input type="file" id="cover-file" accept=".txt">
                            <label for="cover-file" class="file-label">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                    <polyline points="17 8 12 3 7 8"/>
                                    <line x1="12" y1="3" x2="12" y2="15"/>
                                </svg>
                                <span>Or upload cover text file</span>
                            </label>
                        </div>
                        <div class="char-info">
                            <span class="hint capacity">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline; vertical-align: middle; margin-right: 4px;">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="12" y1="16" x2="12" y2="12"/>
                                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                                </svg>
                                You can hide up to <strong id="max-capacity">0</strong> characters in this cover text
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="secret-message">Secret Message</label>
                        <textarea id="secret-message" name="secretMessage" rows="4" placeholder="Enter your secret message..." required></textarea>
                        <div class="secret-char-info">
                            <span class="hint">Characters: <strong id="secret-char-count">0</strong></span>
                            <span class="hint" id="capacity-status"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="hide-algorithm">Encryption</label>
                            <select id="hide-algorithm" name="algorithm" required>
                                <option value="caesar">Caesar Cipher</option>
                                <option value="aes">AES (XOR)</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="hide-key">Key</label>
                            <input type="text" id="hide-key" name="key" placeholder="Enter encryption key" required>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <span>Hide Message</span>
                        <svg class="btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="12 5 19 12 12 19"/>
                        </svg>
                    </button>
                </form>

                <div id="hide-result" class="result-card" style="display: none;">
                    <div class="result-header">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <h3>Stego Text Generated</h3>
                    </div>
                    <textarea id="stego-output" rows="6" readonly></textarea>
                    <div class="button-group">
                        <button onclick="copyToClipboard('stego-output')" class="btn btn-secondary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                            </svg>
                            <span>Copy</span>
                        </button>
                        <button onclick="downloadText('stego-output', 'stego.txt')" class="btn btn-secondary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/>
                                <line x1="12" y1="15" x2="12" y2="3"/>
                            </svg>
                            <span>Download</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Extract Message View -->
            <div id="extract-view" class="view">
                <form id="extract-form" class="form-card">
                    <div class="form-group">
                        <label for="stego-text">Stego Text</label>
                        <textarea id="stego-text" name="stegoText" rows="6" placeholder="Paste stego text here..."></textarea>
                        <div class="file-upload">
                            <input type="file" id="stego-file" accept=".txt">
                            <label for="stego-file" class="file-label">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                    <polyline points="17 8 12 3 7 8"/>
                                    <line x1="12" y1="3" x2="12" y2="15"/>
                                </svg>
                                <span>Or upload file</span>
                            </label>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="extract-algorithm">Encryption</label>
                            <select id="extract-algorithm" name="algorithm" required>
                                <option value="caesar">Caesar Cipher</option>
                                <option value="aes">AES (XOR)</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="extract-key">Key</label>
                            <input type="text" id="extract-key" name="key" placeholder="Enter encryption key" required>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <span>Extract Message</span>
                        <svg class="btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="12 5 19 12 12 19"/>
                        </svg>
                    </button>
                </form>

                <div id="extract-result" class="result-card" style="display: none;">
                    <div class="result-header">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <h3>Secret Message Extracted</h3>
                    </div>
                    <textarea id="extracted-output" rows="6" readonly></textarea>
                    <div class="button-group">
                        <button onclick="copyToClipboard('extracted-output')" class="btn btn-secondary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                            </svg>
                            <span>Copy</span>
                        </button>
                        <button onclick="downloadText('extracted-output', 'secret.txt')" class="btn btn-secondary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/>
                                <line x1="12" y1="15" x2="12" y2="3"/>
                            </svg>
                            <span>Download</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- About View -->
            <div id="about-view" class="view">
                <div class="about-content">
                    <h2>How It Works</h2>
                    <div class="feature-grid">
                        <div class="feature-card">
                            <div class="feature-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </div>
                            <h3>Encrypt</h3>
                            <p>Your secret message is encrypted using Caesar Cipher or AES</p>
                        </div>
                        <div class="feature-card">
                            <div class="feature-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                    <line x1="1" y1="1" x2="23" y2="23" stroke-width="2"/>
                                </svg>
                            </div>
                            <h3>Hide</h3>
                            <p>Encrypted data is embedded using invisible zero-width Unicode characters</p>
                        </div>
                        <div class="feature-card">
                            <div class="feature-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="22" y1="2" x2="11" y2="13"/>
                                    <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                                </svg>
                            </div>
                            <h3>Share</h3>
                            <p>Share the innocent-looking text anywhere - email, chat, social media</p>
                        </div>
                        <div class="feature-card">
                            <div class="feature-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
                                </svg>
                            </div>
                            <h3>Extract</h3>
                            <p>Only those with the correct key can decrypt and read your message</p>
                        </div>
                    </div>

                    <div class="tech-info">
                        <h3>Technology Stack</h3>
                        <ul>
                            <li><strong>Frontend:</strong> EJS, HTML5, CSS3, JavaScript</li>
                            <li><strong>Backend:</strong> Node.js + Express</li>
                            <li><strong>Core Engine:</strong> C++ for high-performance steganography</li>
                            <li><strong>Encryption:</strong> Caesar Cipher & AES (XOR-based)</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div id="error-box" class="error-box" style="display: none;"></div>
        </main>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
